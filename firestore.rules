rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }

    match /users/{userId} {
      allow read:   if isAuth() && (isOwner(userId) || isAdmin());
      allow create: if isAuth() && isOwner(userId);
      allow update: if isAuth() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    match /accounts/{accountId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      // Sur create, resource n'existe pas — utiliser request.resource
      allow create: if isAdmin()
        || (isAuth()
            && request.resource.data.userId == request.auth.uid
            && accountId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /transactions/{txId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /cards/{cardId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /requests/{reqId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /admin_actions/{actionId} {
      allow read:   if isAuth() && (resource.data.targetUserId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    match /notifications/{notifId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() || isAdmin();
      allow update: if isAuth() && isOwner(resource.data.userId);
      allow delete: if isAuth() && isOwner(resource.data.userId);
    }
  }
}
